# ── Fill these in ────────────────────────────────────────────────────────────
# Identity
subscription_id = "00000000-0000-0000-0000-000000000000" # your Azure subscription
org_id          = ""                                     # your org / tenant id — tagged onto every resource

# Placement & naming
location    = "eastus"
name_prefix = "demo-dev"

# Network (minimal: single /24 VNet, one /26 subnet)
vnet_cidr   = "10.0.0.0/24"
subnet_cidr = "10.0.0.0/26"

# Access — lock SSH to your own IP. "*" opens port 22 to the whole internet.
allowed_ssh_cidr = "*" # e.g. "203.0.113.4/32"

# Compute — set create_vm = false for a network-only stack.
create_vm            = true
admin_username       = "azureuser"
admin_ssh_public_key = ""             # contents of e.g. ~/.ssh/id_ed25519.pub — required when create_vm = true
vm_size              = "Standard_B1s" # cheapest burstable tier
os_disk_type         = "Standard_LRS" # HDD — lowest-cost managed disk

tags = {
  Project     = "azure-demo"
  Environment = "dev"
  ManagedBy   = "terraform"
  Owner       = "you"
}
